# Local: npm run dev loads .env via Node --env-file. Production (Railway) injects vars; no dotenv.
DISCORD_TOKEN=

# DATABASE_URL
# Local: postgres://user:pass@127.0.0.1:5432/dbname
#
# Railway — if "Add reference" shows no suggestions, set the value by hand (Railway resolves it at deploy):
#   1) Bot service → Variables → New Variable → name DATABASE_URL
#   2) Value (exact template, no quotes around the whole thing):
#        ${{ Postgres.DATABASE_URL }}
#      Replace Postgres with your Postgres service name EXACTLY as on the project canvas (rename under service Settings if needed).
#   Docs: https://docs.railway.com/reference/variables (template syntax ${{ NAMESPACE.VAR }})
DATABASE_URL=

# Optional: register slash commands to this guild immediately
# DISCORD_GUILD_ID=

# Optional: respond "Pong!" when this Discord username sends "Ping!"
# BOT_DEBUG_USERNAME=

# Optional override (Railway sets PORT automatically)
# PORT=8080
