# Local: npm run dev loads .env via Node --env-file. Production (Railway) injects vars; no dotenv.
DISCORD_TOKEN=

# DATABASE_URL
# Local: postgres://user:pass@127.0.0.1:5432/dbname
#
# Railway — if "Add reference" shows no suggestions, set the value by hand (Railway resolves it at deploy):
#   1) Bot service → Variables → New Variable → name DATABASE_URL
#   2) Value box: ONLY the template below (no DATABASE_URL= prefix, no wrapping quotes in the UI):
#        ${{ postgres.DATABASE_URL }}
#      Replace postgres with your Postgres service name EXACTLY as on the graph (try Postgres vs postgres).
#   Alternate: reference PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE from Postgres → bot (no DATABASE_URL needed).
#   Docs: https://docs.railway.com/reference/variables
DATABASE_URL=

# Optional: register slash commands to this guild immediately
# DISCORD_GUILD_ID=

# Optional: debug pings.
# BOT_DEBUG_USER_ID    — Discord user ID to ping alongside the officer role when an alert fires.
#                        All normal checks still apply (officer role required, Cyrillic, tracked members).
#                        Get it: Discord → Developer Mode → right-click yourself → Copy User ID.
# BOT_DEBUG_GUILD_IDS  — Comma-separated Discord guild IDs where the debug user should be pinged.
#                        Leave empty to disable. Example: 123456789012345678,987654321098765432
# BOT_DEBUG_USER_ID=
# BOT_DEBUG_GUILD_IDS=

# Optional override (Railway sets PORT automatically)
# PORT=8080
